// BNI 商機交流平台 - Prisma Schema（對應 supabase/schema.sql）
// 使用方式：設定 DATABASE_URL / DIRECT_URL 後執行 npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Member {
  id        String   @id @default(uuid())
  authId    String?  @map("auth_id") @db.Uuid
  name      String
  company   String   @default("")
  industry  String   @default("")
  chapter   String   @default("")
  title     String   @default("")
  phone     String   @default("")
  line      String   @default("")
  email     String   @default("")
  website   String?
  facebook  String?
  instagram String?
  linkedin  String?
  role      String   @default("member")
  color     String   @default("#c8102e")
  media     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  card             ExchangeCard?
  interactionsFrom Interaction[] @relation("from")
  interactionsTo   Interaction[] @relation("to")
  matchesAsSource  MatchScore[]  @relation("matchSource")
  matchesAsTarget  MatchScore[]  @relation("matchTarget")

  @@index([industry])
  @@index([chapter])
  @@map("members")
}

model ExchangeCard {
  memberId  String   @id @map("member_id")
  answers   Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("exchange_cards")
}

model Interaction {
  id        String   @id @default(uuid())
  type      String // '121' | 'referral' | 'cooperation' | 'shared_client'
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  date      DateTime @db.Date
  note      String?
  amount    Decimal?
  closed    Boolean?
  createdAt DateTime @default(now()) @map("created_at")

  from Member @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to   Member @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@index([type, date])
  @@map("interactions")
}

// 交流卡生命週期：多版本商業檔案，完整保留歷史
model CardVersion {
  id        String   @id @default(uuid())
  memberId  String   @map("member_id")
  version   Int
  title     String   @default("")
  answers   Json     @default("{}")
  status    String   @default("draft") // draft | active | completed | archived
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @default("") @map("created_by")
  updatedBy String   @default("") @map("updated_by")

  @@unique([memberId, version])
  @@index([memberId, status])
  @@map("card_versions")
}

// 專案管理：每位會員可建立多個專案
model BizProject {
  id               String   @id @default(uuid())
  memberId         String   @map("member_id")
  name             String
  intro            String   @default("")
  idealReferrals   String   @default("") @map("ideal_referrals")
  industriesNeeded Json     @default("[]") @map("industries_needed")
  resourcesOffered String   @default("") @map("resources_offered")
  expectedClose    String   @default("") @map("expected_close")
  startDate        String   @default("") @map("start_date")
  endDate          String   @default("") @map("end_date")
  isMain           Boolean  @default(false) @map("is_main")
  importance       Int      @default(3)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([memberId])
  @@map("projects")
}

// AI 商機快訊：媒合成功率 >= 85% 時通知雙方
model BizAlertRow {
  id          String   @id @default(uuid())
  memberIds   Json     @default("[]") @map("member_ids")
  pair        Json     @default("{}")
  probability Int
  reasons     Json     @default("[]")
  trigger     String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("biz_alerts")
}

model MatchScore {
  memberId    String   @map("member_id")
  targetId    String   @map("target_id")
  score       Int
  probability Int
  reasons     Json     @default("[]")
  tags        Json     @default("[]")
  computedAt  DateTime @default(now()) @map("computed_at")

  member Member @relation("matchSource", fields: [memberId], references: [id], onDelete: Cascade)
  target Member @relation("matchTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@id([memberId, targetId])
  @@map("match_scores")
}
